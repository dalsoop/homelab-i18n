#!/usr/bin/env bash
# pxi-ainovel — Ai-Novel (LXC 50176, novel.50.internal.kr) 관리 CLI
# 컴포즈 수명 + 자동 한국어화 (프론트엔드 + DB)
# 스크립트 정본: /root/homelab-i18n/ainovel/scripts/zh-to-ko.py, db-zh-to-ko.py
set -euo pipefail

VMID="${AINOVEL_VMID:-50176}"
APP_ROOT="/opt/ainovel"
HOMELAB_I18N="/root/homelab-i18n/ainovel"
FRONTEND_SCRIPT="$HOMELAB_I18N/scripts/zh-to-ko.py"
DB_SCRIPT="$HOMELAB_I18N/scripts/db-zh-to-ko.py"
BACKEND_SCRIPT="$HOMELAB_I18N/scripts/backend-zh-to-ko.py"
BACKEND_FIX_SCRIPT="$HOMELAB_I18N/scripts/backend-final-fix.py"
AUDIT_SCRIPT="$HOMELAB_I18N/scripts/project-audit.py"
EXPORT_SCRIPT="$HOMELAB_I18N/scripts/project-export.py"
IMPORT_SCRIPT="$HOMELAB_I18N/scripts/project-import.py"
TIMER_UNIT="ainovel-translate.timer"
SERVICE_UNIT="ainovel-translate.service"

c_r(){ printf '\033[0;31m%s\033[0m' "$*"; }
c_g(){ printf '\033[0;32m%s\033[0m' "$*"; }
c_b(){ printf '\033[0;34m%s\033[0m' "$*"; }
c_y(){ printf '\033[0;33m%s\033[0m' "$*"; }
log(){ echo "$(c_b '[ainovel]') $*" >&2; }
ok(){ echo "$(c_g '✓') $*" >&2; }
warn(){ echo "$(c_y '⚠') $*" >&2; }
die(){ echo "$(c_r '✗') $*" >&2; exit 1; }

in_lxc(){ pct exec "$VMID" -- bash -lc "$*"; }

require_up(){
  pct config "$VMID" >/dev/null 2>&1 || die "LXC $VMID 없음"
  [ "$(pct status "$VMID" 2>/dev/null | awk '{print $2}')" = "running" ] \
    || die "LXC $VMID 중지됨. pct start $VMID"
}

require_scripts(){
  [ -x "$FRONTEND_SCRIPT" ] || die "$FRONTEND_SCRIPT 없음 (git clone https://github.com/dalsoop/homelab-i18n /root/homelab-i18n)"
  [ -x "$DB_SCRIPT" ] || die "$DB_SCRIPT 없음"
}

compose(){ in_lxc "cd $APP_ROOT && docker compose --env-file .env.docker $*"; }

# ── 수명 ─────────────────────────────────────────────────────────────────
cmd_install(){
  command -v pxi >/dev/null || die "pxi 필요"
  local skip_translate=""
  local skip_auto=""
  local deploy_args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --no-translate) skip_translate="1"; shift ;;
      --no-auto) skip_auto="1"; shift ;;
      *) deploy_args+=("$1"); shift ;;
    esac
  done
  log "ainovel.toml 레시피로 배포"
  pxi run deploy recipe ainovel "${deploy_args[@]}"
  ok "LXC 배포 완료"

  if [ -z "$skip_translate" ]; then
    log "한국어 번역 자동 실행"
    cmd_translate --include-templates
  fi

  if [ -z "$skip_auto" ]; then
    # C4: README 아키텍처와 일치 — 10분 간격 (새 프로젝트 drift 최소화)
    log "자동 번역 타이머 활성화 (*:0/10)"
    cmd_auto_on '*:0/10'
  fi

  ok "설치 완료 — https://novel.50.internal.kr"
}

# H9: svc 인자 whitelist — pct exec bash -lc 인젝션 방지
VALID_SVCS_RE='^(frontend|backend|postgres|redis|rq_worker)$'
require_svc(){
  local svc="$1"
  [[ "$svc" =~ $VALID_SVCS_RE ]] || die "유효한 service: frontend|backend|postgres|redis|rq_worker (입력: $svc)"
}

cmd_up(){ require_up; compose "up -d"; ok "up"; }
cmd_down(){ require_up; compose "down"; ok "down"; }
cmd_ps(){ require_up; compose "ps"; }
cmd_logs(){
  require_up
  local svc="${1:-backend}"
  require_svc "$svc"
  compose "logs -f --tail=100 $svc"
}
cmd_rebuild(){
  require_up
  local svc="${1:-frontend}"
  require_svc "$svc"
  log "rebuild $svc"
  compose "up -d --build $svc"
  ok "rebuild 완료"
}

# ── 번역 ─────────────────────────────────────────────────────────────────
cmd_scan(){
  require_up; require_scripts
  log "프론트엔드 한자 스캔"
  "$FRONTEND_SCRIPT" scan --lxc "$VMID" || true
  echo
  log "DB 한자 스캔"
  "$DB_SCRIPT" scan || true
}

cmd_translate_frontend(){
  require_up; require_scripts
  log "프론트엔드 번역 (TranslateGemma 4-way, run until zero)"
  "$FRONTEND_SCRIPT" run --lxc "$VMID" --max-rounds 5 "$@"
  ok "프론트엔드 번역 완료"
}

cmd_translate_db(){
  require_up; require_scripts
  log "DB 번역"
  "$DB_SCRIPT" translate "$@"
  ok "DB 번역 완료"
}

cmd_translate_backend(){
  require_up
  [ -x "$BACKEND_SCRIPT" ] || die "$BACKEND_SCRIPT 없음"
  log "backend Python seed 번역 (TranslateGemma 4-way)"
  "$BACKEND_SCRIPT" run
  [ -x "$BACKEND_FIX_SCRIPT" ] && python3 "$BACKEND_FIX_SCRIPT" || true
  compose "restart backend rq_worker" >/dev/null
  ok "backend 번역 + 재시작 완료"
}

cmd_translate(){
  require_up; require_scripts
  local include_llm=""
  local rebuild_after="1"
  while [ $# -gt 0 ]; do
    case "$1" in
      --include-templates) include_llm="--include-templates"; shift ;;
      --no-rebuild) rebuild_after=""; shift ;;
      *) break ;;
    esac
  done
  # C3: timer · 수동 동시 실행 방지. 이미 돌고 있으면 즉시 종료.
  # sentinel 로 재진입 구분 (flock 이 -c 로 호출할 때는 sentinel 세트)
  if [ "${AINOVEL_TRANSLATE_LOCKED:-0}" != "1" ]; then
    log "flock 획득 시도 (/var/lock/ainovel-translate.lock)"
    AINOVEL_TRANSLATE_LOCKED=1 exec flock -n /var/lock/ainovel-translate.lock "$0" translate "$@"
    warn "다른 번역 작업 진행 중 — skip"
    return 0
  fi
  log "=== 1단계: 프론트엔드 번역 ==="
  "$FRONTEND_SCRIPT" run --lxc "$VMID" --max-rounds 5
  log "=== 2단계: DB 번역 ==="
  "$DB_SCRIPT" translate $include_llm
  if [ -n "$rebuild_after" ]; then
    log "=== 3단계: frontend 재빌드 ==="
    compose "up -d --build frontend" >/dev/null
    ok "재빌드 완료"
  fi
  log "=== 4단계: 최종 스캔 ==="
  "$FRONTEND_SCRIPT" scan --lxc "$VMID" | tail -3
  "$DB_SCRIPT" scan | tail -3
  ok "translate 완료"
}

# ── 자동 번역 timer (pve 호스트) ─────────────────────────────────────────
cmd_auto_on(){
  local interval="${1:-daily}"
  log "systemd timer 설치 (간격: $interval)"
  cat > "/etc/systemd/system/$SERVICE_UNIT" <<EOF
[Unit]
Description=Ai-Novel 한자 자동 번역 (zh → ko)
After=network-online.target

[Service]
Type=oneshot
# C3: flock 으로 수동 실행과의 레이스 방지. 이미 돌고 있으면 즉시 종료.
ExecStart=/usr/bin/flock -n /var/lock/ainovel-translate.lock /usr/local/bin/pxi-ainovel translate --include-templates
TimeoutStartSec=2h
SuccessExitStatus=0 1
StandardOutput=journal
StandardError=journal
EOF
  cat > "/etc/systemd/system/$TIMER_UNIT" <<EOF
[Unit]
Description=Ai-Novel 자동 번역 타이머

[Timer]
OnCalendar=$interval
Persistent=true
RandomizedDelaySec=15min

[Install]
WantedBy=timers.target
EOF
  systemctl daemon-reload
  systemctl enable --now "$TIMER_UNIT"
  ok "자동 번역 활성화 ($interval)"
  systemctl list-timers "$TIMER_UNIT" --no-pager
}

cmd_auto_off(){
  log "자동 번역 비활성"
  systemctl disable --now "$TIMER_UNIT" 2>/dev/null || true
  rm -f "/etc/systemd/system/$TIMER_UNIT" "/etc/systemd/system/$SERVICE_UNIT"
  systemctl daemon-reload
  ok "자동 번역 해제"
}

cmd_auto_status(){
  if [ -f "/etc/systemd/system/$TIMER_UNIT" ]; then
    systemctl status "$TIMER_UNIT" --no-pager | head -15
    echo
    systemctl list-timers "$TIMER_UNIT" --no-pager | head -3
  else
    warn "자동 번역 설치 안 됨 (pxi-ainovel auto-on 으로 활성화)"
  fi
}

cmd_auto_run_now(){
  log "타이머 서비스 수동 실행"
  systemctl start "$SERVICE_UNIT"
  journalctl -u "$SERVICE_UNIT" -n 30 --no-pager
}

# ── LLM 모드 토글 (Gemma 4 ↔ TranslateGemma) ────────────────────────────
# 96GB VRAM 중 4.7GB(Whisper 60102) + 17GB(TG shim) + 31GB(Gemma 4)의 합이
# GPU별로 24GB 한도를 넘나들어 동시 상주가 불안정. 모드별 단독 상주로 운용.
GEMMA_VMID=60104
TG_VMID=60108

cmd_llm_mode(){
  local mode="${1:-status}"
  case "$mode" in
    gemma|novel)
      log "모드 전환: Gemma 4 (소설 생성)"
      ssh -o ConnectTimeout=5 root@10.0.60.1 "pct status $TG_VMID 2>&1" | grep -q running \
        && ssh root@10.0.60.1 "pct stop $TG_VMID" 2>&1 | tail -1
      cmd_auto_off >/dev/null 2>&1 || true
      ssh -o ConnectTimeout=5 root@10.0.60.1 "pct status $GEMMA_VMID 2>&1" | grep -q stopped \
        && ssh root@10.0.60.1 "pct start $GEMMA_VMID" 2>&1 | tail -1
      ok "Gemma 4 모드 — Ai-Novel 에서 소설 생성 가능 (http://10.0.60.104:8091)"
      ;;
    translate|번역)
      log "모드 전환: TranslateGemma (번역 배치)"
      ssh -o ConnectTimeout=5 root@10.0.60.1 "pct status $GEMMA_VMID 2>&1" | grep -q running \
        && ssh root@10.0.60.1 "pct stop $GEMMA_VMID" 2>&1 | tail -1
      ssh -o ConnectTimeout=5 root@10.0.60.1 "pct status $TG_VMID 2>&1" | grep -q stopped \
        && ssh root@10.0.60.1 "pct start $TG_VMID" 2>&1 | tail -1
      cmd_auto_on '*:0/10' >/dev/null 2>&1 || true
      ok "TranslateGemma 모드 — 자동 번역 타이머 10분 간격 활성"
      ;;
    off|stop)
      log "모드 전환: 전체 stop (VRAM 회수)"
      ssh root@10.0.60.1 "pct stop $GEMMA_VMID $TG_VMID 2>&1 | head -3" || true
      cmd_auto_off >/dev/null 2>&1 || true
      ok "모든 LLM stop"
      ;;
    status|"")
      local g=$(ssh -o ConnectTimeout=5 root@10.0.60.1 "pct status $GEMMA_VMID 2>&1 | awk '{print \$2}'" 2>&1)
      local t=$(ssh -o ConnectTimeout=5 root@10.0.60.1 "pct status $TG_VMID 2>&1 | awk '{print \$2}'" 2>&1)
      local timer=$(systemctl is-active "$TIMER_UNIT" 2>/dev/null || echo "inactive")
      log "Gemma 4 LXC $GEMMA_VMID: $g"
      log "TranslateGemma LXC $TG_VMID: $t"
      log "자동 번역 타이머: $timer"
      ssh -o ConnectTimeout=5 root@10.0.60.1 'nvidia-smi --query-gpu=index,memory.used,memory.total --format=csv,noheader' 2>&1 | head
      ;;
    *)
      die "모드: gemma | translate | off | status"
      ;;
  esac
}

# ── 프로젝트 데이터 API (audit / export / import / reset) ────────────────
# DB SQL 레이어로 프로젝트 메타·본편·그래프·기억·분석 전부 다루는 커맨드.
# audit 으로 빈 곳 확인 → import 로 JSON 주입하는 흐름.

cmd_project(){
  local sub="${1:-help}"
  shift || true
  case "$sub" in
    list)
      require_up
      compose "exec -T postgres psql -U ainovel -d ainovel -c 'SELECT id, name, genre FROM projects ORDER BY updated_at DESC;'"
      ;;
    audit)
      [ -n "${1:-}" ] || die "프로젝트 id 필요: pxi run ainovel project audit <id>"
      "$AUDIT_SCRIPT" "$1"
      ;;
    export)
      [ -n "${1:-}" ] || die "pxi run ainovel project export <id> [out.json]"
      if [ -n "${2:-}" ]; then
        "$EXPORT_SCRIPT" "$1" > "$2"
        ok "export → $2 ($(wc -c <"$2") bytes)"
      else
        "$EXPORT_SCRIPT" "$1"
      fi
      ;;
    import)
      [ -n "${1:-}" ] && [ -n "${2:-}" ] || die "pxi run ainovel project import <id> <file.json> [--dry-run]"
      "$IMPORT_SCRIPT" "$1" "$2" "${3:-}"
      ;;
    reset-tasks)
      [ -n "${1:-}" ] || die "pxi run ainovel project reset-tasks <id>"
      local pid="$1"
      require_up
      compose "exec -T postgres psql -U ainovel -d ainovel -c \"
        DELETE FROM project_task_events WHERE task_id IN (SELECT id FROM project_tasks WHERE project_id='$pid' AND status IN ('failed','cancelled'));
        DELETE FROM project_tasks WHERE project_id='$pid' AND status IN ('failed','cancelled');
        DELETE FROM memory_change_set_items WHERE change_set_id IN (SELECT id FROM memory_change_sets WHERE project_id='$pid' AND status='proposed');
        DELETE FROM memory_change_sets WHERE project_id='$pid' AND status='proposed';
        SELECT status, COUNT(*) FROM project_tasks WHERE project_id='$pid' GROUP BY status;\""
      ok "failed·cancelled task + proposed change_set 정리 완료"
      ;;
    help|"")
      cat <<'EOF'
pxi run ainovel project <cmd>

  list                                모든 프로젝트 (id/name/genre)
  audit <id>                          빈 테이블·불완전 지점 JSON 리포트
  export <id> [out.json]              프로젝트 전체 상태 JSON 덤프
  import <id> <in.json> [--dry-run]   JSON 을 테이블에 upsert
  reset-tasks <id>                    failed·cancelled task + proposed change_set 청소

JSON 스키마 (export/import 공통):
  meta           — name, genre, logline
  settings       — world_setting, style_guide, constraints
  outline        — title, content_md
  chapters[]     — number, title, plan, summary, content_md, status
  characters[]   — name, role, profile, notes
  entities[]     — type, name, summary, attributes
  relations[]    — from(name), to(name), type, description
  worldbook[]    — title, content_md, priority, enabled, constant, keywords
  foreshadows[]  — chapter, resolved_at_chapter, title, content, resolved
  glossary[]     — term, aliases, sources
  evidence[]     — chapter, quote, attributes
  story_memories[] — chapter, type, title, content, importance, tags
  plot_analysis[]  — chapter, overall, coherence, engagement, pacing, report, analysis
  numeric_tables[] — key, name, schema, rows
EOF
      ;;
    *) die "알 수 없는 project 서브커맨드: $sub"; ;;
  esac
}

# ── 챕터 조작 (본편 내용 직접 다루기) ─────────────────────────────────────

cmd_chapter(){
  local sub="${1:-list}"; shift || true
  require_up
  case "$sub" in
    list)
      [ -n "${1:-}" ] || die "pxi run ainovel chapter list <proj_id>"
      compose "exec -T postgres psql -U ainovel -d ainovel -c \"SELECT number, title, status, LENGTH(content_md) AS len FROM chapters WHERE project_id='$1' ORDER BY number;\""
      ;;
    show)
      [ -n "${1:-}" ] && [ -n "${2:-}" ] || die "pxi run ainovel chapter show <proj_id> <n>"
      compose "exec -T postgres psql -U ainovel -d ainovel -At -c \"SELECT content_md FROM chapters WHERE project_id='$1' AND number=$2;\""
      ;;
    set-status)
      [ -n "${1:-}" ] && [ -n "${2:-}" ] && [ -n "${3:-}" ] || die "pxi run ainovel chapter set-status <proj_id> <n> <drafting|done>"
      compose "exec -T postgres psql -U ainovel -d ainovel -c \"UPDATE chapters SET status='$3', updated_at=NOW() WHERE project_id='$1' AND number=$2;\""
      ok "ch$2 → $3"
      ;;
    generate)
      [ -n "${1:-}" ] && [ -n "${2:-}" ] || die "pxi run ainovel chapter generate <proj_id> <n>"
      local pid="$1" n="$2"
      log "chapter $n 초안 생성 (Gemma 4)"
      compose "exec -T backend python3 -c \"
from app.db.session import SessionLocal
from app.services.project_task_service import schedule_chapter_done_tasks
from app.models.chapter import Chapter
db = SessionLocal()
ch = db.query(Chapter).filter_by(project_id='$pid', number=$n).first()
if not ch: raise SystemExit('chapter $n not found')
t = schedule_chapter_done_tasks(db=db, project_id='$pid', actor_user_id='admin', request_id='cli-gen', chapter_id=str(ch.id), chapter_token=ch.updated_at.isoformat().replace('+00:00','Z')+'-cli', reason='cli_generate')
print('scheduled', len(t), 'tasks')
\""
      ok "스케줄됨 — TaskCenter 에서 확인"
      ;;
    analyze)
      [ -n "${1:-}" ] && [ -n "${2:-}" ] || die "pxi run ainovel chapter analyze <proj_id> <n>"
      log "chapter $2 분석 (Gemma 4, plot_analysis 갱신)"
      cmd_chapter generate "$1" "$2"
      ;;
    *) die "chapter 서브커맨드: list | show | set-status | generate | analyze"
  esac
}

# ── LLM 질의 ────────────────────────────────────────────────────────────

cmd_ask(){
  local pid="${1:-}" ; shift || true
  local query="$*"
  [ -n "$pid" ] && [ -n "$query" ] || die "pxi run ainovel ask <proj_id> <질문>"
  require_up
  log "Gemma 4 에게 질의 (프로젝트 context 포함)"
  compose "exec -T backend python3 -c \"
from app.db.session import SessionLocal
from app.llm.client import call_llm
from app.models.chapter import Chapter
from app.models.story_memory import StoryMemory

db = SessionLocal()
chs = db.query(Chapter).filter_by(project_id='$pid').order_by(Chapter.number).limit(3).all()
mems = db.query(StoryMemory).filter_by(project_id='$pid').order_by(StoryMemory.importance_score.desc()).limit(8).all()
ctx = '\\n'.join([f'[ch{c.number} {c.title}] {(c.summary or c.content_md[:400])}' for c in chs])
ctx += '\\n\\n기억:\\n' + '\\n'.join([f'- {m.title}: {m.content[:200]}' for m in mems])
r = call_llm(provider='openai_compatible', base_url='http://10.0.60.104:8091/v1', api_key='sk-local', model='gemma-4-31b-q8', system='프로젝트 assistant. 한국어로 간결히.', user=f'컨텍스트:\\n{ctx}\\n\\n질문: $query', params={'temperature':0.5,'max_tokens':2000}, timeout_seconds=90)
print(r.text[:3000])
\""
}

# ── 인프라 (embedding / RAG) ───────────────────────────────────────────

cmd_embed(){
  local action="${1:-status}"
  case "$action" in
    on)
      ssh root@10.0.60.1 "pct exec $GEMMA_VMID -- systemctl enable --now llama-embed" 2>&1 | tail -2
      sleep 3
      curl -sm 5 -o /dev/null -w "embed HTTP: %{http_code}\n" http://10.0.60.104:8092/v1/models
      ;;
    off)
      ssh root@10.0.60.1 "pct exec $GEMMA_VMID -- systemctl disable --now llama-embed" 2>&1 | tail -2
      ok "embed stopped"
      ;;
    status)
      ssh root@10.0.60.1 "pct exec $GEMMA_VMID -- systemctl is-active llama-embed" 2>&1
      curl -sm 3 -o /dev/null -w "embed HTTP: %{http_code}\n" http://10.0.60.104:8092/v1/models
      ;;
    *) die "embed: on | off | status"
  esac
}

cmd_rag_rebuild(){
  [ -n "${1:-}" ] || die "pxi run ainovel rag-rebuild <proj_id>"
  require_up
  local pid="$1"
  compose "exec -T postgres psql -U ainovel -d ainovel -c \"UPDATE project_settings SET vector_index_dirty=true, last_vector_build_at=NULL WHERE project_id='$pid';\""
  compose "exec -T backend python3 -c \"
from app.db.session import SessionLocal
from app.services.vector_rag_service import schedule_vector_rebuild_task
r = schedule_vector_rebuild_task(db=SessionLocal(), project_id='$pid', actor_user_id='admin', request_id='cli-rag', reason='cli_rebuild')
print('task:', r)
\""
  ok "rag rebuild 스케줄 — task 완료 대기"
}

# ── 유틸 (sql / shell / health / vram) ──────────────────────────────

cmd_sql(){
  [ -n "${1:-}" ] || die "pxi run ainovel sql \"<query>\""
  require_up
  compose "exec -T postgres psql -U ainovel -d ainovel -c \"$1\""
}

cmd_shell(){
  require_up
  local svc="${1:-backend}"
  require_svc "$svc"
  log "$svc 컨테이너 shell"
  pct exec "$VMID" -- bash -lc "cd $APP_ROOT && docker compose --env-file .env.docker exec $svc bash"
}

cmd_health(){
  echo "[ainovel]"
  curl -sk -o /dev/null -w "  https://novel.50.internal.kr/: %{http_code}\n" https://novel.50.internal.kr/
  curl -sk -o /dev/null -w "  api/health: %{http_code}\n" https://novel.50.internal.kr/api/health
  echo "[llm]"
  curl -sm 3 -o /dev/null -w "  Gemma 4 (8091): %{http_code}\n" http://10.0.60.104:8091/v1/models
  curl -sm 3 -o /dev/null -w "  Embed (8092): %{http_code}\n" http://10.0.60.104:8092/v1/models
  curl -sm 3 -o /dev/null -w "  TG shim 8082: %{http_code}\n" http://10.0.60.108:8082/translate -X POST -H 'Content-Type: application/json' -d '{"text":"test","source_lang_code":"zh","target_lang_code":"ko"}'
  echo "[compose]"
  compose "ps --format '  {{.Name}}: {{.Status}}'"
}

cmd_vram(){
  ssh -o ConnectTimeout=3 root@10.0.60.1 'nvidia-smi --query-gpu=index,memory.used,memory.total,utilization.gpu --format=csv,noheader' 2>&1
}

# ── 상태/헬스 ─────────────────────────────────────────────────────────────
cmd_status(){
  require_up
  log "LXC $VMID 상태"
  pct status "$VMID"
  echo
  log "컨테이너"
  compose "ps"
  echo
  log "한자 수"
  "$FRONTEND_SCRIPT" scan --lxc "$VMID" 2>/dev/null | tail -1
  "$DB_SCRIPT" scan 2>/dev/null | tail -1
  echo
  local http=$(curl -sk -o /dev/null -w '%{http_code}' "https://novel.50.internal.kr/" || echo "??")
  log "novel.50.internal.kr: HTTP $http"
}

cmd_help(){
  cat <<'EOF'
pxi-ainovel — Ai-Novel 관리 CLI (LXC 50176)

수명:
  install [...opts]                  ainovel.toml 레시피 기반 배포
  up                                 docker compose up -d
  down                               docker compose down
  ps                                 컨테이너 목록
  logs [svc]                         로그 (기본 backend)
  rebuild [svc]                      이미지 재빌드 (기본 frontend)
  status                             컨테이너 + 한자 수 + HTTP 상태

번역 (zh → ko):
  scan                               프론트엔드 + DB 한자 카운트
  translate-frontend [...]           프론트 번역만 (한자 0까지)
  translate-db [...]                 DB 번역만
  translate-backend                  backend Python seed 번역 + 재시작
                                     (새 프로젝트 생성이 한국어 seed로 되게)
  translate [--include-templates]    프론트 + DB 번역 + rebuild
                                     --include-templates: LLM 프롬프트까지
                                     --no-rebuild: 재빌드 스킵

프로젝트 데이터 API:
  project list                       모든 프로젝트 목록
  project audit <id>                 빈 테이블·미흡 지점 JSON 리포트
  project export <id> [out.json]     현재 상태 JSON 덤프
  project import <id> <file.json>    JSON 으로 테이블 upsert (--dry-run)
  project reset-tasks <id>           failed·cancelled task + proposed cs 청소

챕터:
  chapter list <proj>                장 목록
  chapter show <proj> <n>            장 본문 stdout
  chapter set-status <proj> <n> <s>  drafting|done
  chapter generate <proj> <n>        Gemma 4로 auto_update 전체 스케줄
  chapter analyze <proj> <n>         plot_analysis 재생성

LLM 질의·인프라:
  ask <proj> <질문>                  Gemma 4에 프로젝트 컨텍스트 포함 질의
  embed on|off|status                nomic-embed-text 서버 토글
  rag-rebuild <proj>                 vector index 재빌드

유틸:
  sql "<query>"                      postgres 직접 쿼리
  shell [svc]                        컴포즈 서비스 shell (기본 backend)
  health                             endpoint 전수 체크
  vram                               GPU VRAM 현황

LLM 모드 (Gemma 4 ↔ TG 토글):
  llm-mode status                    현재 모드 (Gemma 4 / TG / off)
  llm-mode gemma                     Gemma 4 단독 (TG stop, 타이머 off) — 소설 생성용
  llm-mode translate                 TranslateGemma 단독 (Gemma stop, 타이머 10분) — 번역 배치
  llm-mode off                       전체 stop (VRAM 회수)

자동 번역 (pve 호스트 systemd timer):
  auto-on [interval]                 타이머 활성 (기본 daily, "hourly" / "*:0/30" 등 지원)
  auto-off                           타이머 제거
  auto-status                        타이머 상태
  auto-run-now                       지금 한 번 돌리기

환경:
  AINOVEL_VMID=50176 (LXC VMID 오버라이드)

예시:
  pxi-ainovel status
  pxi-ainovel translate --include-templates
  pxi-ainovel auto-on daily
EOF
}

main(){
  local cmd="${1:-help}"
  shift || true
  case "$cmd" in
    install|up|down|ps|logs|rebuild|status|scan|translate|help) "cmd_$cmd" "$@" ;;
    translate-frontend) cmd_translate_frontend "$@" ;;
    translate-db) cmd_translate_db "$@" ;;
    translate-backend) cmd_translate_backend "$@" ;;
    project) cmd_project "$@" ;;
    chapter) cmd_chapter "$@" ;;
    ask) cmd_ask "$@" ;;
    embed) cmd_embed "$@" ;;
    rag-rebuild) cmd_rag_rebuild "$@" ;;
    sql) cmd_sql "$@" ;;
    shell) cmd_shell "$@" ;;
    health) cmd_health "$@" ;;
    vram) cmd_vram "$@" ;;
    llm-mode|llm) cmd_llm_mode "$@" ;;
    auto-on) cmd_auto_on "$@" ;;
    auto-off) cmd_auto_off "$@" ;;
    auto-status) cmd_auto_status "$@" ;;
    auto-run-now) cmd_auto_run_now "$@" ;;
    *) die "알 수 없는 서브커맨드: $cmd (help 참조)" ;;
  esac
}

main "$@"
